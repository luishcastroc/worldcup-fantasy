{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "worldcup-fantasy": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@analogjs/vite-plugin-angular:vite",
          "options": {
            "configFile": "vite.config.mts",
            "main": "src/main.ts",
            "outputPath": "dist/worldcup-fantasy",
            "tsConfig": "tsconfig.app.json"
          },
          "configurations": {
            "production": {
              "sourcemap": false,
              "mode": "production"
            },
            "development": {
              "mode": "development"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@analogjs/vite-plugin-angular:vite-dev-server",
          "options": {
            "buildTarget": "worldcup-fantasy:build",
            "port": 4200
          },
          "configurations": {
            "production": {
              "buildTarget": "worldcup-fantasy:build:production"
            },
            "development": {
              "buildTarget": "worldcup-fantasy:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@analogjs/vitest-angular:test"
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
